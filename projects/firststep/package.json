{
  "name": "firststep",
  "version": "3.0.0",
  "description": "中文本土化轻量级自主 AI Agent，专注多源收入与低成本生存",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "node dist/index.js --setup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "ai-agent",
    "autonomous",
    "income",
    "crypto",
    "automation",
    "airdrop",
    "firststep"
  ],
  "author": "FirstStep Team",
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.26.0",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "ethers": "^6.11.1",
    "node-cron": "^3.0.3",
    "puppeteer": "^21.11.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tronweb": "^5.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
