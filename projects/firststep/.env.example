# FirstStep v3.0 - Environment Variables

# Database
DATABASE_PATH=./data/firststep.db

# Wallet Private Keys (encrypted in production)
# Format: encrypted:... or raw (not recommended)
TRON_PRIVATE_KEY=encrypted:your_encrypted_key_here
BSC_PRIVATE_KEY=encrypted:your_encrypted_key_here
POLYGON_PRIVATE_KEY=encrypted:your_encrypted_key_here

# Feishu (Lark) Configuration
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# API Keys for Inference (optional)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Security Settings
DAILY_SPEND_LIMIT=10
REQUIRE_APPROVAL_ABOVE=5

# Memory Settings
MEMORY_LIMIT_MB=2048
BROWSER_MEMORY_LIMIT_MB=512

# Logging
LOG_LEVEL=info
LOG_FILE=./data/logs/firststep.log

# Node Environment
NODE_ENV=production
